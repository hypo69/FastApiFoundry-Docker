# -*- coding: utf-8 -*-
# =============================================================================
# Process Name: Environment Variables — Secrets Only
# =============================================================================
# Description:
#   .env stores ONLY secrets and machine-specific overrides.
#   All non-secret settings (ports, paths, flags) live in config.json.
#
#   Rule: if it has no password/token/key — it belongs in config.json.
#
# File: .env.example
# Project: FastApiFoundry (Docker)
# Version: 0.6.0
# Author: hypo69
# Copyright: © 2026 hypo69
# =============================================================================

# =============================================================================
# HuggingFace — token for gated models (Gemma, Llama, Mistral)
# Get token: https://huggingface.co/settings/tokens
# =============================================================================
HF_TOKEN=hf_your_token_here

# =============================================================================
# Foundry AI — override auto-detected URL (optional)
# Leave empty to let start.ps1 auto-detect the port.
# =============================================================================
# FOUNDRY_BASE_URL=http://localhost:50477/v1

# =============================================================================
# FastAPI security — API key to protect all endpoints (optional)
# Leave empty to disable authentication.
# =============================================================================
# API_KEY=your_secret_api_key_here

# =============================================================================
# External AI provider API keys
# Managed via Settings → API Keys tab in the web UI.
# =============================================================================
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# OPENROUTER_API_KEY=sk-or-...
# MISTRAL_API_KEY=...
# GROQ_API_KEY=gsk_...
# DEEPSEEK_API_KEY=...
# XAI_API_KEY=...

# =============================================================================
# GitHub — for private repo access (optional)
# =============================================================================
# GITHUB_PAT=ghp_your_personal_access_token_here

# =============================================================================
# llama.cpp — explicit binary path (optional)
# Set only if auto-detection from bin/ fails.
# All other llama.cpp settings (port, model_path, auto_start) are in config.json.
# =============================================================================
# LLAMA_SERVER_PATH=.\bin\llama-b8802-bin-win-cpu-x64\llama-server.exe
