# -*- coding: utf-8 -*-
# =============================================================================
# Process Name: Environment Variables — Secrets Only
# =============================================================================
# Description:
#   .env stores ONLY secrets and machine-specific overrides.
#   All non-secret settings (ports, paths, flags) live in config.json.
#
#   Rule: if it has no password/token/key — it belongs in config.json.
#
# File: .env.example
# Project: FastApiFoundry (Docker)
# Version: 0.6.1
# Author: hypo69
# Copyright: © 2026 hypo69
# =============================================================================

# =============================================================================
# SECURITY — API keys to protect endpoints (optional, leave empty to disable)
# =============================================================================
API_KEY=
SECRET_KEY=

# =============================================================================
# HuggingFace — token for gated models (Gemma, Llama, Mistral)
# Get token: https://huggingface.co/settings/tokens  (role: Read)
# Model directory is set in config.json → directories.hf_models
# =============================================================================
HF_TOKEN=

# =============================================================================
# External AI provider API keys
# Managed via Settings → API Keys tab in the web UI.
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
FOUNDRY_API_KEY=
# OPENROUTER_API_KEY=
# MISTRAL_API_KEY=
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# XAI_API_KEY=

# =============================================================================
# Foundry AI — override auto-detected URL (optional)
# Leave empty — start.ps1 auto-detects the port via tasklist + netstat.
# =============================================================================
# FOUNDRY_BASE_URL=http://localhost:50477/v1

# =============================================================================
# llama.cpp — explicit binary path (optional)
# Set only if auto-detection from bin/ fails.
# All other llama.cpp settings live in config.json → llama_cpp section.
# =============================================================================
LLAMA_SERVER_PATH=

# =============================================================================
# FTP server credentials (used by mcp/src/servers/ftp_mcp.py)
# =============================================================================
FTP_HOST=
FTP_USER=
FTP_PASSWORD=
FTP_PORT=21

# =============================================================================
# FTP deploy paths (used by deploy scripts)
# =============================================================================
FTP_DOCS_RU=/domains/davidka.net/public_html/ai_assist/docs/ru
FTP_DOCS_EN=/domains/davidka.net/public_html/ai_assist/docs/en

# =============================================================================
# GitHub — Personal Access Token for private repo access (optional)
# Also used by mcp/src/servers/github MCP server.
# =============================================================================
GITHUB_PAT=

# =============================================================================
# Telegram Admin Bot — monitoring, Foundry control, logs, RAG management
# Restricted to TELEGRAM_ADMIN_IDS. Token from @BotFather.
# =============================================================================
TELEGRAM_ADMIN_TOKEN=
# Comma-separated Telegram user IDs: 123456789,987654321
TELEGRAM_ADMIN_IDS=

# =============================================================================
# Telegram HelpDesk Bot — customer-facing support bot
# Answers via RAG + active AI model. Open to all Telegram users.
# RAG profile configured in config.json → telegram_helpdesk.rag_profile
# =============================================================================
TELEGRAM_HELPDESK_TOKEN=

# =============================================================================
# Tesseract OCR — explicit path (optional)
# Set automatically by install\install-tesseract.ps1.
# Leave empty if tesseract is already in system PATH.
# =============================================================================
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
