# -*- coding: utf-8 -*-
# =============================================================================
# Название процесса: Environment Variables Configuration
# =============================================================================
# Описание:
#   Переменные окружения для FastAPI Foundry
#   Содержит чувствительные данные: API ключи, пароли, токены
#
# File: .env.example
# Project: FastApiFoundry (Docker)
# Version: 0.2.1
# Author: hypo69
# Copyright: © 2026 hypo69
# Copyright: © 2026 hypo69
# Date: 9 декабря 2025
# =============================================================================

# =============================================================================
# GitHub Configuration
# =============================================================================
GITHUB_USER=your_username
GITHUB_PASSWORD=your_password_or_token
GITHUB_PAT=ghp_your_personal_access_token_here
GITHUB_API_URL=https://api.github.com

# =============================================================================
# FastAPI Configuration
# =============================================================================
API_KEY=your_secret_api_key_here
SECRET_KEY=your_jwt_secret_key_here
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# Foundry AI Configuration
# =============================================================================
FOUNDRY_BASE_URL=http://localhost:50477/v1
FOUNDRY_API_KEY=optional_foundry_api_key
FOUNDRY_TIMEOUT=30
# Dynamic port auto-detected by Foundry (legacy, set if auto-detection fails)
# FOUNDRY_DYNAMIC_PORT=50477

# =============================================================================
# Database Configuration (если используется)
# =============================================================================
DATABASE_URL=sqlite:///./fastapi_foundry.db
# DATABASE_URL=postgresql://user:password@localhost/dbname

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=DEBUG
LOG_FILE=logs/app.log

# =============================================================================
# RAG System Configuration
# =============================================================================
RAG_INDEX_PATH=rag_index
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# =============================================================================
# llama.cpp Configuration
# =============================================================================
LLAMA_MODEL_PATH=~/.models/gemma-2-2b-it-Q6_K.gguf
LLAMA_BASE_URL=http://127.0.0.1:8080/v1
LLAMA_PORT=8080
LLAMA_HOST=127.0.0.1
LLAMA_AUTO_START=false
GGUF_SEARCH_DIRS=~/.models
# Explicit path to llama-server.exe (optional, auto-detected if not set)
# Set automatically by install.ps1 if llama.cpp archive found in bin/
# LLAMA_SERVER_PATH=.\bin\llama-b8802-bin-win-cpu-x64\llama-server.exe

# =============================================================================
# HuggingFace Configuration
# =============================================================================
# Токен для закрытых моделей (Gemma, Llama и др.):
# 1. Создайте токен на https://huggingface.co/settings/tokens
# 2. Примите лицензию на странице модели (huggingface.co/<model_id>)
HF_TOKEN=hf_your_token_here
HUGGING_FACE_TOKEN=hf_your_token_here
HF_MODELS_DIR=~/.models

# =============================================================================
# External APIs (примеры)
# =============================================================================
OPENAI_API_KEY=sk-your_openai_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
HUGGINGFACE_API_KEY=hf_your_huggingface_key_here

# =============================================================================
# Email Configuration (если нужна отправка email)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_TLS=true

# =============================================================================
# Redis Configuration (если используется кэширование)
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your_redis_password

# =============================================================================
# Development/Production Mode
# =============================================================================
ENVIRONMENT=development
DEBUG=true