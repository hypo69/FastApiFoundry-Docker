# -*- coding: utf-8 -*-
# =============================================================================
# Process Name: Environment Variables — Secrets Only
# =============================================================================
# Description:
#   .env stores ONLY secrets and machine-specific overrides.
#   All non-secret settings (ports, paths, flags) live in config.json.
#
#   Rule: if it has no password/token/key — it belongs in config.json.
#
# File: .env.example
# Project: FastApiFoundry (Docker)
# Version: 0.6.1
# Changes in 0.6.1:
#   - Synced with .env: added SECRET_KEY, GEMINI_API_KEY, ANTHROPIC_API_KEY
#   - All keys present (commented) so setup-env.ps1 can replace them
# Author: hypo69
# Copyright: © 2026 hypo69
# =============================================================================

# =============================================================================
# SECURITY — API key to protect all endpoints (optional)
# Leave empty to disable authentication.
# =============================================================================
API_KEY=
SECRET_KEY=

# =============================================================================
# HuggingFace — token for gated models (Gemma, Llama, Mistral)
# Get token: https://huggingface.co/settings/tokens
# Directory for downloaded models is set in config.json → directories.hf_models
# =============================================================================
HF_TOKEN=

# =============================================================================
# External AI provider API keys
# Managed via Settings → API Keys tab in the web UI.
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# MISTRAL_API_KEY=
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# XAI_API_KEY=

# =============================================================================
# Foundry AI — override auto-detected URL (optional)
# Leave empty to let start.ps1 auto-detect the port.
# =============================================================================
# FOUNDRY_BASE_URL=http://localhost:50477/v1

# =============================================================================
# GitHub — for private repo access (optional)
# =============================================================================
GITHUB_PAT=

# =============================================================================
# llama.cpp — explicit binary path (optional)
# Set only if auto-detection from bin/ fails.
# All other llama.cpp settings (port, model_path, auto_start) are in config.json.
# =============================================================================
LLAMA_SERVER_PATH=

# =============================================================================
# Telegram Admin Bot — monitoring and Foundry management
# Restricted to TELEGRAM_ADMIN_IDS. Token from @BotFather.
# =============================================================================
TELEGRAM_ADMIN_TOKEN=
# Comma-separated Telegram user IDs allowed to use the admin bot
TELEGRAM_ADMIN_IDS=

# =============================================================================
# Telegram HelpDesk Bot — customer-facing support bot
# Answers user questions via RAG + active AI model. Open to all users.
# RAG profile configured in config.json → telegram_helpdesk.rag_profile
# =============================================================================
TELEGRAM_HELPDESK_TOKEN=

# =============================================================================
# Tesseract OCR — explicit path to tesseract.exe (optional)
# Set automatically by install\install-tesseract.ps1.
# Leave empty if tesseract is already in system PATH.
# =============================================================================
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
