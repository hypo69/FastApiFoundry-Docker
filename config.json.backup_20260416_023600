{
  "fastapi_server": {
    "host": "0.0.0.0",
    "port": 9696,
    "auto_find_free_port": true,
    "mode": "dev",
    "workers": 2,
    "reload": true,
    "log_level": "DEBUG",
    "cors_origins": [
      "*"
    ]
  },
  "foundry_ai": {
    "base_url": "${FOUNDRY_BASE_URL}",
    "api_key": "${FOUNDRY_API_KEY}",
    "default_model": "gemma-2-2b-it-Q6_K.gguf",
    "auto_load_default": false,
    "temperature": 0.7,
    "top_p": 0.9,
    "top_k": 40,
    "max_tokens": 2048,
    "timeout": 300
  },
  "rag_system": {
    "enabled": true,
    "index_dir": "./rag_index",
    "model": "sentence-transformers/all-MiniLM-L6-v2",
    "chunk_size": 1000,
    "top_k": 5
  },
  "huggingface": {
    "token": "${HF_TOKEN}",
    "models_dir": "${HF_MODELS_DIR:~/.models/hf}",
    "device": "auto",
    "default_max_new_tokens": 512,
    "default_temperature": 0.7
  },
  "llama_cpp": {
    "model_path": "${LLAMA_MODEL_PATH}",
    "base_url": "${LLAMA_BASE_URL:http://127.0.0.1:9780/v1}",
    "port": 9780,
    "host": "127.0.0.1",
    "ctx_size": 4096,
    "threads": 0,
    "n_gpu_layers": 0,
    "auto_start": false
  },
  "security": {
    "api_key": "1234",
    "secret_key": "${SECRET_KEY}",
    "https_enabled": false,
    "cors_origins": [
      "*"
    ],
    "ssl_cert_file": "~/.ssl/cert.pem",
    "ssl_key_file": "~/.ssl/key.pem"
  },
  "logging": {
    "level": "INFO",
    "file": "logs/fastapi-foundry.log"
  },
  "mcp_powershell_servers": {
    "enabled": true,
    "settings_file": "./mcp-powershell-servers/settings.json",
    "auto_start": [],
    "description": "MCP PowerShell серверы — управление через /api/v1/mcp-powershell"
  },
  "mcp_server": {
    "name": "aistros-foundry",
    "version": "1.0.0",
    "description": "AiStros Foundry MCP Server - Interface for Microsoft Foundry local AI models",
    "author": "hypo69",
    "license": "CC BY-NC-SA 4.0",
    "homepage": "https://aistros.com",
    "mcpVersion": "2024-11-05",
    "base_url": "http://localhost:51601/v1/",
    "default_model": "deepseek-r1-distill-qwen-7b-generic-cpu:3",
    "timeout": 30,
    "capabilities": {
      "tools": [
        "generate_text",
        "generate_horoscope_foundry",
        "list_foundry_models",
        "get_foundry_status"
      ],
      "resources": [
        "foundry://models/list",
        "foundry://config/current"
      ]
    }
  },
  "web_interface": {
    "api_base": "http://localhost:9696/api/v1",
    "auto_refresh_interval": 30000,
    "logs_refresh_interval": 10000,
    "max_chat_history": 100
  },
  "examples": {
    "client_demo": {
      "enabled": true,
      "timeout": 30
    },
    "rag_demo": {
      "enabled": true,
      "query": "WordPress плагины AiStros",
      "top_k": 3
    },
    "mcp_demo": {
      "enabled": true
    },
    "model_demo": {
      "enabled": true
    }
  },
  "docker": {
    "image": "fastapi-foundry:0.2.1",
    "container_name": "fastapi-foundry-docker",
    "network": "fastapi-foundry-network",
    "foundry_host": "localhost",
    "foundry_port": 8008,
    "rag_enabled": true,
    "healthcheck": {
      "interval": "30s",
      "timeout": "10s",
      "retries": 3,
      "start_period": "40s"
    },
    "volumes": [
      "./logs:/app/logs",
      "./rag_index:/app/rag_index"
    ]
  },
  "port_management": {
    "conflict_resolution": "kill_process",
    "auto_find_free_port": true,
    "port_range_start": 9696,
    "port_range_end": 9796
  },
  "development": {
    "debug": true,
    "verbose": true,
    "temp_dir": "./temp",
    "environment": "${ENVIRONMENT:development}"
  }
}