{
  "fastapi_server": {
    "host": "0.0.0.0",
    "port": 9696,
    "auto_find_free_port": false,
    "mode": "dev",
    "workers": 1
  },
  "foundry_ai": {
    "base_url": "http://localhost:63995/v1/",
    "default_model": "foundry::qwen2.5-coder-0.5b-instruct-generic-cpu:4",
    "temperature": 0.7,
    "max_tokens": 2048,
    "auto_start": false,
    "auto_load_default": false,
    "startup_model_mode": "default",
    "startup_custom_model": "",
    "models_dir": "~/.foundry/cache/models"
  },
  "rag_system": {
    "enabled": true,
    "index_dir": "~/.rag/train_data",
    "source_dirs": [
      "~/.rag/train_data"
    ],
    "model": "sentence-transformers/all-MiniLM-L6-v2",
    "chunk_size": 1000,
    "top_k": 5,
    "compact_threshold_percent": 20,
    "compact_check_interval_hours": 24
  },
  "security": {
    "api_key": "",
    "https_enabled": false
  },
  "logging": {
    "level": "DEBUG",
    "file": "",
    "max_bytes_mb": 10,
    "backup_count": 5,
    "structured_file": "",
    "retention_hours": 24,
    "suppress_loggers": [],
    "console": true,
    "file_handler": true,
    "errors_file": true,
    "structured": true
  },
  "development": {
    "debug": true,
    "verbose": true
  },
  "translator": {
    "enabled": false,
    "default_provider": "mymemory",
    "request_timeout_sec": 30,
    "mymemory_email": "",
    "libretranslate_url": "https://libretranslate.com",
    "libretranslate_fallback_url": "https://translate.argosopentech.com",
    "libretranslate_api_key": ""
  },
  "docs_server": {
    "enabled": true,
    "port": 9697
  },
  "llama_cpp": {
    "port": 9780,
    "host": "127.0.0.1",
    "server_path": "",
    "models_dir": "~/.models",
    "default_model": "",
    "auto_start": false,
    "model_path": "gemma-2-2b-it-Q6_K.gguf"
  },
  "ollama": {
    "base_url": "http://localhost:11434",
    "temperature": 0.7,
    "top_p": 0.9,
    "top_k": 50,
    "max_tokens": 2048
  },
  "opencode": {
    "enabled": true,
    "auto_start": true,
    "host": "0.0.0.0",
    "port": 9699,
    "command": "opencode"
  },
  "directories": {
    "models": "~/.models",
    "rag": "~/.rag",
    "hf_models": "~/.hf_models"
  },
  "ftp": {
    "host": "",
    "user": "",
    "port": 21,
    "docs_dir": "/domains/davidka.net/public_html/ai_assist/docs"
  },
  "custom": {
    "base_url": "http://localhost:9696/v1",
    "api_key": ""
  },
  "text_extractor": {
    "max_file_size_mb": 20,
    "processing_timeout_seconds": 300,
    "ocr_languages": "rus+eng",
    "web_page_timeout": 30,
    "max_images_per_page": 20,
    "enable_javascript": false,
    "enable_resource_limits": true
  },
  "huggingface": {
    "models_dir": "./models/hf",
    "device": "auto",
    "default_max_new_tokens": 512,
    "default_temperature": 0.7
  }
}
